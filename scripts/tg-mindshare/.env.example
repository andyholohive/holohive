# Get these from https://my.telegram.org → API development tools
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash

# Your phone number (with country code, e.g. +82101234567)
TG_PHONE=+821012345678

# Your app's mindshare API endpoint
API_URL=http://localhost:3000/api/mindshare

# CRON_SECRET from your .env.local (must match)
CRON_SECRET=your_cron_secret

# How often to scan channels (seconds)
SCAN_INTERVAL=300

# Supabase (to read monitored channels + client keywords)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_service_role_key
