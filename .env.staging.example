# holohive-staging — Supabase staging project (CRM rebuild Day-0, Yano's #1).
# Copy to .env.staging and fill from the staging project's dashboard.
# NEVER commit the filled .env.staging (it's gitignored alongside .env.local).

# Supabase staging (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# Direct Postgres connection (Dashboard → Project Settings → Database → Connection string)
# Used by scripts/snapshot-prod-to-staging.sh
STAGING_DB_URL=postgresql://postgres:<password>@db.<staging-ref>.supabase.co:5432/postgres

# Prod connection — snapshot SOURCE. Read-only use in the snapshot script.
PROD_DB_URL=postgresql://postgres:<password>@db.<prod-ref>.supabase.co:5432/postgres
